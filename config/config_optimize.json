{
    // 模型优化配置 (PyTorch → ONNX → TensorRT)
    // 由 ModelOptimizer CLI 读取
    "model_path": "models/model.pt",   // 输入: PyTorch TorchScript 模型路径
    "onnx_path": "models/model.onnx",  // 中间: ONNX 导出路径
    "engine_path": "models/model.engine", // 输出: TensorRT 引擎路径
    "input_shape": [1, 3, 640, 640],   // 导出时使用的虚拟输入形状
    "precision": "fp16",               // TensorRT 精度: fp16 / int8 / fp32
    "opset": 17,                       // ONNX opset 版本号
    "dynamic_batch": true,             // 是否启用动态 batch 维度
    "max_batch_size": 8,               // 最大 batch 大小 (dynamic_batch 时有效)
    "calibrator": {                    // INT8 校准器配置
        "calib_dir": "data/calib",     // 校准数据集目录
        "num_calib": 100,              // 校准样本数量
        "algorithm": "entropy_v2"      // 校准算法: entropy_v2 / minmax / percentile
    }
}
